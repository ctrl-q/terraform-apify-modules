{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "addLabels": [
    "dependencies"
  ],
  "bumpVersion": "patch",
  "extends": [
    ":enablePreCommit",
    ":enableVulnerabilityAlerts",
    ":prHourlyLimitNone",
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "major": {
    "minimumReleaseAge": "1 month"
  },
  "minor": {
    "minimumReleaseAge": "2 weeks"
  }
}
